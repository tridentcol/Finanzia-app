################################################################################
#  Finanzia — variables de entorno
#
#  1. Copia este archivo a .env.local       cp .env.example .env.local
#  2. Llena los valores siguiendo las instrucciones de abajo.
#  3. La app NO arranca si falta una variable obligatoria (validado por Zod en
#     src/lib/env.ts).
################################################################################


# ─── App ──────────────────────────────────────────────────────────────────────
# URL pública del proyecto. En dev déjalo en localhost.
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ─── Supabase ─────────────────────────────────────────────────────────────────
# Dónde: https://supabase.com/dashboard/project/_/settings/database
#
# En "Connection string" verás varias opciones. Necesitas DOS:
#
#  • DATABASE_URL  → la del "Transaction pooler"  (puerto 6543)
#                    Es la que usa la app en runtime (serverless friendly).
#  • DIRECT_URL    → la del "Direct connection"   (puerto 5432)
#                    Es la que usan las migraciones de Drizzle.
#
# Marca el checkbox "Display connection pooler" si no ves la opción.
# Pega el string tal cual; reemplaza [YOUR-PASSWORD] por la contraseña que
# definiste al crear el proyecto.
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.xxxxxxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Dónde: https://supabase.com/dashboard/project/_/settings/api
#
# Sección "Project URL".
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co

# Misma página, sección "Project API keys".
#
#  • NEXT_PUBLIC_SUPABASE_ANON_KEY    → la fila etiquetada como  "anon  public"
#  • SUPABASE_SERVICE_ROLE_KEY        → la fila etiquetada como  "service_role  secret"
#
# Si tu dashboard ya migró al nuevo sistema:
#  • anon         = "Publishable key" (sb_publishable_…)
#  • service_role = "Secret key"      (sb_secret_…)
#
# NUNCA expongas la service_role en el cliente.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=


# ─── Clerk ────────────────────────────────────────────────────────────────────
# Dónde: https://dashboard.clerk.com  →  tu aplicación  →  "API keys"
#
#  • NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY → bloque "Publishable key" (pk_…)
#  • CLERK_SECRET_KEY                  → bloque "Secret keys"     (sk_…)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Dónde: https://dashboard.clerk.com  →  tu aplicación  →  "Webhooks"
#
# Después de crear el endpoint apuntando a
#   https://<tu-dominio>/api/webhooks/clerk
# Clerk te mostrará un "Signing Secret" (whsec_…). Pégalo aquí.
# En dev local puedes usar ngrok o el local tunnel del Clerk dashboard.
CLERK_WEBHOOK_SECRET=


# ─── Anthropic (Claude) ───────────────────────────────────────────────────────
# Dónde: https://console.anthropic.com/settings/keys
# Click "Create Key", copia el valor (sk-ant-…).
ANTHROPIC_API_KEY=


# ─── OpenAI (embeddings + cerebro del copiloto) ───────────────────────────────
# Dónde: https://platform.openai.com/api-keys
# Embeddings (text-embedding-3-small) y, si COPILOT_LLM_PROVIDER=openai, el
# modelo de chat del copiloto. NUNCA commitear la key: va solo en .env.local.
OPENAI_API_KEY=


# ─── Copiloto LLM (opcional — defaults en código) ─────────────────────────────
# Proveedor y modelo del cerebro del copiloto. Todas opcionales.
#   COPILOT_LLM_PROVIDER   openai | anthropic        (default openai)
#   COPILOT_LLM_MODEL      id del modelo             (default gpt-5.4-mini)
#   COPILOT_REASONING_EFFORT  minimal|low|medium|high (default medium)
#   COPILOT_TEXT_VERBOSITY    low|medium|high          (default low)
#   COPILOT_STORE          1 → OpenAI guarda el hilo (default 0 por privacidad)
#   COPILOT_FORCE_LLM      1 → salta el ruteo local-first, todo al LLM (pruebas)
COPILOT_LLM_PROVIDER=
COPILOT_LLM_MODEL=
COPILOT_REASONING_EFFORT=
COPILOT_TEXT_VERBOSITY=
COPILOT_STORE=
COPILOT_FORCE_LLM=


# ─── Upstash Redis ────────────────────────────────────────────────────────────
# Dónde: https://console.upstash.com  →  crea una "Redis Database"  →  pestaña "REST API"
#
# Copia los dos valores que aparecen ahí; los nombres en el dashboard ya
# coinciden con las variables que usamos aquí.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# ─── Trigger.dev (background jobs) ────────────────────────────────────────────
# Dónde: https://cloud.trigger.dev  →  tu proyecto  →  "API Keys"
# Usa la "Secret key" (tr_pat_… o tr_dev_…).
TRIGGER_API_KEY=
TRIGGER_API_URL=https://api.trigger.dev


# ─── Exchange rates (opcional) ────────────────────────────────────────────────
# Dónde: https://exchangerate.host  →  tu cuenta  →  "API Access Key"
# Solo necesario si vas a usar el tier paid. En MVP puedes dejarlo vacío y
# llamar al endpoint público.
EXCHANGE_RATE_API_KEY=


# ─── Sentry (observabilidad) ──────────────────────────────────────────────────
# Dónde: https://sentry.io  →  Settings  →  Projects  →  tu proyecto  →
#        "Client Keys (DSN)"  →  copia el valor "DSN".
SENTRY_DSN=


# ─── Cron ─────────────────────────────────────────────────────────────────────
# Token aleatorio que protege los endpoints de /api/cron/*.
# Generar con:
#   openssl rand -hex 32
CRON_SECRET=
